---
import AgentModelMark from "./AgentModelMark.astro";
import { inferAgentModelMeta } from "@/agent/model-meta";

type AgentSidecar = {
  provider?: string;
  model?: string;
  degraded?: boolean;
  degraded_reason?: string | null;
  public_commentary?: string;
  related_posts?: {
    post_id: string;
    title: string;
    route_path: string;
    relation?: string;
  }[];
  summary?: string;
  structural_review?: string;
  technical_review?: string;
  strengths?: string[];
  concerns?: string[];
  severity?: "info" | "warn" | "error";
  confidence?: number;
  generated_at?: string;
  memory_refs?: string[];
  knowledge_refs?: string[];
  notes?: string[];
};

interface Props {
  sidecar?: AgentSidecar | null;
  class?: string;
}

const { sidecar = null, class: className = "" } = Astro.props;

const severityTone = {
  info: "border-accent/25 bg-accent/8 text-accent",
  warn: "border-amber-500/30 bg-amber-500/10 text-amber-600 dark:text-amber-300",
  error: "border-red-500/30 bg-red-500/10 text-red-600 dark:text-red-300",
};

const hasData = Boolean(sidecar);
const confidence =
  typeof sidecar?.confidence === "number"
    ? `${Math.round(sidecar.confidence * 100)}%`
    : null;
const generatedAt = sidecar?.generated_at
  ? new Date(sidecar.generated_at).toLocaleDateString("zh-CN", {
      year: "numeric",
      month: "short",
      day: "numeric",
    })
  : null;
const strengths = Array.isArray(sidecar?.strengths) ? sidecar.strengths : [];
const concerns = Array.isArray(sidecar?.concerns) ? sidecar.concerns : [];
const memoryRefs = [
  ...new Set([
    ...(Array.isArray(sidecar?.memory_refs) ? sidecar.memory_refs : []),
    ...(Array.isArray(sidecar?.knowledge_refs) ? sidecar.knowledge_refs : []),
  ]),
];
const notes = Array.isArray(sidecar?.notes) ? sidecar.notes : [];
const relatedPosts = Array.isArray(sidecar?.related_posts)
  ? sidecar.related_posts
  : [];
const publicCommentary =
  typeof sidecar?.public_commentary === "string" &&
  sidecar.public_commentary.trim()
    ? sidecar.public_commentary.trim()
    : "";
const modelMeta = inferAgentModelMeta(sidecar?.provider, sidecar?.model);

function escapeHtml(value: string) {
  return value
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

function normalizeLimitedMarkdown(value: string) {
  return value
    .replace(/```[\s\S]*?```/gu, "")
    .replace(/^#{1,6}\s+/gmu, "")
    .replace(/!\[[^\]]*\]\([^)]*\)/gu, "")
    .replace(/\[([^\]]+)\]\([^)]*\)/gu, "$1")
    .replace(/<[^>]*>/gu, "")
    .trim();
}

function renderInlineMarkdown(value: string) {
  return escapeHtml(value)
    .replace(
      /`([^`]+)`/gu,
      '<code class="rounded bg-muted px-1 py-0.5">$1</code>'
    )
    .replace(/\*\*([^*]+)\*\*/gu, "<strong>$1</strong>")
    .replace(/\*([^*]+)\*/gu, "<em>$1</em>");
}

function renderLimitedMarkdown(value: string) {
  const blocks = normalizeLimitedMarkdown(value)
    .split(/\n{2,}/u)
    .map(block => block.trim())
    .filter(Boolean);

  return blocks
    .map(block => {
      const lines = block
        .split(/\n/u)
        .map(line => line.trim())
        .filter(Boolean);

      if (lines.length > 0 && lines.every(line => /^[-*]\s+/u.test(line))) {
        const items = lines
          .map(line => line.replace(/^[-*]\s+/u, ""))
          .map(line => `<li>${renderInlineMarkdown(line)}</li>`)
          .join("");

        return `<ul>${items}</ul>`;
      }

      return `<p>${renderInlineMarkdown(lines.join(" "))}</p>`;
    })
    .join("");
}
---

<section
  id="agent-panel"
  aria-labelledby="agent-panel-title"
  class:list={[
    "rounded-2xl border border-border bg-muted/30 p-5 lg:flex lg:flex-col",
    className,
  ]}
>
  <div class="flex items-start justify-between gap-3 lg:flex-none">
    <div>
      <p
        class="text-[0.65rem] font-semibold tracking-[0.22em] text-foreground/45 uppercase"
      >
        Agent Review
      </p>
      <h2
        id="agent-panel-title"
        class="mt-2 text-base font-semibold text-foreground"
      >
        文章点评
      </h2>
    </div>
    {
      sidecar?.severity && (
        <span
          class:list={[
            "rounded-full border px-2.5 py-1 text-[0.7rem] font-semibold tracking-[0.18em] uppercase",
            severityTone[sidecar.severity],
          ]}
        >
          {sidecar.severity}
        </span>
      )
    }
  </div>

  {
    hasData ? (
      <div class="mt-5 space-y-5 text-sm leading-6 text-foreground/82 lg:min-h-0 lg:flex-1 lg:overflow-y-auto lg:overscroll-contain lg:pr-1">
        <div class="rounded-2xl border border-border bg-background/70 p-4">
          <div class="flex items-start gap-3">
            <AgentModelMark brand={modelMeta.brand} />
            <div class="min-w-0 flex-1">
              <p class="text-[0.68rem] font-semibold tracking-[0.18em] text-foreground/45 uppercase">
                Review Model
              </p>
              <div class="mt-1 flex flex-wrap items-center gap-2">
                <p class="text-sm font-semibold text-foreground">
                  {modelMeta.brandLabel}
                </p>
                {sidecar?.model && (
                  <span class="rounded-full border border-border bg-muted/45 px-2.5 py-0.5 text-[0.72rem] font-medium text-foreground/72">
                    {sidecar.model}
                  </span>
                )}
              </div>
              <p class="mt-2 text-xs leading-5 text-foreground/62">
                {modelMeta.summary}
              </p>
              <div class="mt-2 flex flex-wrap gap-2 text-[0.72rem] text-foreground/60">
                {sidecar?.provider && (
                  <span>Provider {modelMeta.providerLabel}</span>
                )}
                {modelMeta.modelLabel && (
                  <span>Model {modelMeta.modelLabel}</span>
                )}
              </div>
            </div>
          </div>
        </div>

        {sidecar?.degraded && (
          <div class="rounded-lg border border-amber-500/35 bg-amber-500/10 px-3 py-2 text-xs leading-5 text-amber-700 dark:text-amber-200">
            本条为本地规则保底生成，Gemini Agent Review 未完成。
            {sidecar.degraded_reason}
          </div>
        )}

        {publicCommentary ? (
          <>
            <div
              class="space-y-3 text-[0.92rem] leading-7 text-foreground/84 [&_code]:text-[0.85em] [&_li]:border-s-2 [&_li]:border-border [&_li]:ps-3 [&_p]:m-0 [&_strong]:text-foreground [&_ul]:space-y-2"
              set:html={renderLimitedMarkdown(publicCommentary)}
            />

            {relatedPosts.length > 0 && (
              <div class="space-y-2 border-t border-border pt-4">
                <p class="text-[0.68rem] font-semibold tracking-[0.18em] text-foreground/45 uppercase">
                  Related Reading
                </p>
                <div class="space-y-2">
                  {relatedPosts.map(item => (
                    <a
                      href={item.route_path}
                      class="block rounded-lg border border-border bg-background/65 px-3 py-2 transition hover:border-accent/35 hover:bg-background"
                    >
                      <span class="text-[0.68rem] font-semibold tracking-[0.14em] text-foreground/42 uppercase">
                        {item.relation ?? "Related"}
                      </span>
                      <p class="mt-1 text-sm leading-5 font-medium text-foreground">
                        {item.title}
                      </p>
                    </a>
                  ))}
                </div>
              </div>
            )}
          </>
        ) : (
          <>
            {sidecar?.summary && (
              <div class="space-y-1.5">
                <p class="text-[0.68rem] font-semibold tracking-[0.18em] text-foreground/45 uppercase">
                  Summary
                </p>
                <p>{sidecar.summary}</p>
              </div>
            )}

            {sidecar?.structural_review && (
              <div class="space-y-1.5">
                <p class="text-[0.68rem] font-semibold tracking-[0.18em] text-foreground/45 uppercase">
                  Structural
                </p>
                <p>{sidecar.structural_review}</p>
              </div>
            )}

            {sidecar?.technical_review && (
              <div class="space-y-1.5">
                <p class="text-[0.68rem] font-semibold tracking-[0.18em] text-foreground/45 uppercase">
                  Technical
                </p>
                <p>{sidecar.technical_review}</p>
              </div>
            )}

            {strengths.length > 0 && (
              <div class="space-y-2">
                <p class="text-[0.68rem] font-semibold tracking-[0.18em] text-foreground/45 uppercase">
                  Strengths
                </p>
                <ul class="space-y-2">
                  {strengths.map(item => (
                    <li class="border-s-2 border-accent/45 ps-3">{item}</li>
                  ))}
                </ul>
              </div>
            )}

            <div class="space-y-2">
              <p class="text-[0.68rem] font-semibold tracking-[0.18em] text-foreground/45 uppercase">
                Concerns
              </p>
              {concerns.length > 0 ? (
                <ul class="space-y-2">
                  {concerns.map(item => (
                    <li class="border-s-2 border-border ps-3">{item}</li>
                  ))}
                </ul>
              ) : (
                <p class="text-foreground/65">当前没有高优先级负面点评。</p>
              )}
            </div>
          </>
        )}

        <div class="flex flex-wrap gap-x-4 gap-y-2 border-t border-border pt-4 text-[0.72rem] text-foreground/58">
          {!publicCommentary && confidence && <span>置信度 {confidence}</span>}
          {generatedAt && <span>生成于 {generatedAt}</span>}
          {memoryRefs.length > 0 && (
            <span>引用记忆 {memoryRefs.length} 项</span>
          )}
        </div>

        {notes.length > 0 && (
          <p class="text-xs leading-5 text-foreground/55">{notes[0]}</p>
        )}
      </div>
    ) : (
      <div class="mt-5 space-y-3 text-sm leading-6 text-foreground/72 lg:min-h-0 lg:flex-1 lg:overflow-y-auto lg:overscroll-contain lg:pr-1">
        <p>
          该文章还没有生成 sidecar
          JSON，因此旁栏暂时只展示空态，不会触发任何在线请求。
        </p>
        <p class="text-foreground/55">
          可运行 <code>./agent &lt;post&gt;</code> 生成静态点评。
        </p>
      </div>
    )
  }
</section>
