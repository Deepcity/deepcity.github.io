---
import type { AgentModelBrand } from "@/agent/model-meta";

interface Props {
  brand: AgentModelBrand;
  class?: string;
}

const { brand, class: className } = Astro.props;

const tones: Record<AgentModelBrand, string> = {
  chatgpt:
    "border-emerald-500/25 bg-emerald-500/10 text-emerald-700 dark:text-emerald-300",
  grok: "border-slate-500/25 bg-slate-500/10 text-slate-700 dark:text-slate-200",
  gemini: "border-sky-500/25 bg-sky-500/10 text-sky-700 dark:text-sky-300",
  claude:
    "border-orange-500/25 bg-orange-500/10 text-orange-700 dark:text-orange-300",
  qwen: "border-violet-500/25 bg-violet-500/10 text-violet-700 dark:text-violet-300",
  heuristic:
    "border-zinc-500/25 bg-zinc-500/10 text-zinc-700 dark:text-zinc-300",
  unknown:
    "border-border bg-muted/35 text-foreground/70 dark:text-foreground/80",
};
---

<span
  aria-hidden="true"
  class:list={[
    "inline-flex size-11 items-center justify-center rounded-2xl border",
    tones[brand],
    className,
  ]}
>
  {
    brand === "chatgpt" && (
      <svg viewBox="0 0 24 24" class="size-6 fill-none" stroke="currentColor">
        <path
          d="M12 3.5 8.6 5.3v3.9L12 11l3.4-1.8V5.3z"
          stroke-width="1.6"
          stroke-linejoin="round"
        />
        <path
          d="M8.6 5.3 5.2 7.2v3.9L8.6 13m6.8-7.7 3.4 1.9v3.9L15.4 13M8.6 13v3.9l3.4 1.8 3.4-1.8V13"
          stroke-width="1.6"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
        <circle cx="12" cy="12" r="1.7" fill="currentColor" stroke="none" />
      </svg>
    )
  }
  {
    brand === "grok" && (
      <svg viewBox="0 0 24 24" class="size-6 fill-none" stroke="currentColor">
        <path
          d="M6 5.5 18 18.5M18 5.5 6 18.5"
          stroke-width="2.2"
          stroke-linecap="round"
        />
        <circle cx="12" cy="12" r="2" fill="currentColor" stroke="none" />
      </svg>
    )
  }
  {
    brand === "gemini" && (
      <svg viewBox="0 0 24 24" class="size-6 fill-none" stroke="currentColor">
        <path
          d="m12 4 1.7 4.3L18 10l-4.3 1.7L12 16l-1.7-4.3L6 10l4.3-1.7z"
          stroke-width="1.8"
          stroke-linejoin="round"
        />
        <path
          d="m18 4 .9 2.1L21 7l-2.1.9L18 10l-.9-2.1L15 7l2.1-.9z"
          fill="currentColor"
          stroke="none"
        />
      </svg>
    )
  }
  {
    brand === "claude" && (
      <svg viewBox="0 0 24 24" class="size-6 fill-none" stroke="currentColor">
        <circle cx="12" cy="12" r="3.2" stroke-width="1.8" />
        <path
          d="M12 3.5v3M12 17.5v3M3.5 12h3M17.5 12h3M6.4 6.4l2.1 2.1M15.5 15.5l2.1 2.1M17.6 6.4l-2.1 2.1M8.5 15.5l-2.1 2.1"
          stroke-width="1.8"
          stroke-linecap="round"
        />
      </svg>
    )
  }
  {
    brand === "qwen" && (
      <svg viewBox="0 0 24 24" class="size-6 fill-none" stroke="currentColor">
        <path
          d="M12 5a7 7 0 1 0 0 14 7 7 0 0 0 5.2-2.3"
          stroke-width="2"
          stroke-linecap="round"
        />
        <path
          d="m14 14 5 5M15.5 8.5h2.5v2.5"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    )
  }
  {
    brand === "heuristic" && (
      <svg viewBox="0 0 24 24" class="size-6 fill-none" stroke="currentColor">
        <path
          d="M7 6.5 4.5 12 7 17.5M17 6.5 19.5 12 17 17.5M10 7.5h4M9.5 12h5M10 16.5h4"
          stroke-width="1.9"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    )
  }
  {
    brand === "unknown" && (
      <svg viewBox="0 0 24 24" class="size-6 fill-current">
        <circle cx="7" cy="7" r="1.8" />
        <circle cx="17" cy="7" r="1.8" />
        <circle cx="12" cy="12" r="1.8" />
        <circle cx="7" cy="17" r="1.8" />
        <circle cx="17" cy="17" r="1.8" />
      </svg>
    )
  }
</span>
