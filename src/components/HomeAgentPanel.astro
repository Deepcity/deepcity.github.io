---
import AgentModelMark from "./AgentModelMark.astro";
import { inferAgentModelMeta } from "@/agent/model-meta";

type RecommendedPath = {
  label: string;
  href: string;
  description?: string;
};

type HomeAgentSidecar = {
  page_id?: string;
  title?: string;
  provider?: string;
  model?: string;
  summary?: string;
  agent_role?: string;
  site_overview?: string;
  focus_topics?: string[];
  highlights?: string[];
  recommended_paths?: RecommendedPath[];
  content_stats?: {
    total_posts?: number;
    featured_posts?: number;
    latest_post_title?: string;
    primary_topics?: string[];
  };
  confidence?: number;
  generated_at?: string;
  notes?: string[];
};

interface Props {
  sidecar?: HomeAgentSidecar | null;
}

const { sidecar = null } = Astro.props;

const hasData = Boolean(sidecar);
const modelMeta = inferAgentModelMeta(sidecar?.provider, sidecar?.model);
const focusTopics = Array.isArray(sidecar?.focus_topics)
  ? sidecar.focus_topics
  : [];
const highlights = Array.isArray(sidecar?.highlights) ? sidecar.highlights : [];
const recommendedPaths = Array.isArray(sidecar?.recommended_paths)
  ? sidecar.recommended_paths
  : [];
const notes = Array.isArray(sidecar?.notes) ? sidecar.notes : [];
const confidence =
  typeof sidecar?.confidence === "number"
    ? `${Math.round(sidecar.confidence * 100)}%`
    : null;
const generatedAt = sidecar?.generated_at
  ? new Date(sidecar.generated_at).toLocaleDateString("zh-CN", {
      year: "numeric",
      month: "short",
      day: "numeric",
    })
  : null;
---

<section
  id="home-agent-panel"
  aria-labelledby="home-agent-panel-title"
  class="rounded-2xl border border-border bg-muted/30 p-5"
>
  <div class="flex items-start justify-between gap-3">
    <div>
      <p
        class="text-[0.65rem] font-semibold tracking-[0.22em] text-foreground/45 uppercase"
      >
        Site Agent
      </p>
      <h2
        id="home-agent-panel-title"
        class="mt-2 text-base font-semibold text-foreground"
      >
        {sidecar?.title ?? "首页 Agent 导览"}
      </h2>
    </div>
    {
      sidecar?.page_id && (
        <span class="rounded-full border border-border bg-background/70 px-2.5 py-1 text-[0.72rem] font-medium text-foreground/62">
          {sidecar.page_id}
        </span>
      )
    }
  </div>

  {
    hasData ? (
      <div class="mt-5 space-y-5 text-sm leading-6 text-foreground/82">
        <div class="rounded-2xl border border-border bg-background/70 p-4">
          <div class="flex items-start gap-3">
            <AgentModelMark brand={modelMeta.brand} />
            <div class="min-w-0 flex-1">
              <p class="text-[0.68rem] font-semibold tracking-[0.18em] text-foreground/45 uppercase">
                Guide Source
              </p>
              <div class="mt-1 flex flex-wrap items-center gap-2">
                <p class="text-sm font-semibold text-foreground">
                  {modelMeta.brandLabel}
                </p>
                {sidecar?.model && (
                  <span class="rounded-full border border-border bg-muted/45 px-2.5 py-0.5 text-[0.72rem] font-medium text-foreground/72">
                    {sidecar.model}
                  </span>
                )}
              </div>
              <p class="mt-2 text-xs leading-5 text-foreground/62">
                该面板通过构建期生成的静态 sidecar
                总结首页内容，不在访问时发起在线请求。
              </p>
            </div>
          </div>
        </div>

        {sidecar?.summary && (
          <div class="space-y-1.5">
            <p class="text-[0.68rem] font-semibold tracking-[0.18em] text-foreground/45 uppercase">
              Summary
            </p>
            <p>{sidecar.summary}</p>
          </div>
        )}

        {sidecar?.agent_role && (
          <div class="space-y-1.5">
            <p class="text-[0.68rem] font-semibold tracking-[0.18em] text-foreground/45 uppercase">
              Agent Role
            </p>
            <p>{sidecar.agent_role}</p>
          </div>
        )}

        {sidecar?.site_overview && (
          <div class="space-y-1.5">
            <p class="text-[0.68rem] font-semibold tracking-[0.18em] text-foreground/45 uppercase">
              Site Overview
            </p>
            <p>{sidecar.site_overview}</p>
          </div>
        )}

        {focusTopics.length > 0 && (
          <div class="space-y-2">
            <p class="text-[0.68rem] font-semibold tracking-[0.18em] text-foreground/45 uppercase">
              Focus Topics
            </p>
            <div class="flex flex-wrap gap-2">
              {focusTopics.map(topic => (
                <span class="rounded-full border border-border bg-background/70 px-3 py-1 text-[0.78rem] text-foreground/72">
                  {topic}
                </span>
              ))}
            </div>
          </div>
        )}

        {highlights.length > 0 && (
          <div class="space-y-2">
            <p class="text-[0.68rem] font-semibold tracking-[0.18em] text-foreground/45 uppercase">
              Highlights
            </p>
            <ul class="space-y-2">
              {highlights.map(item => (
                <li class="border-s-2 border-accent/45 ps-3">{item}</li>
              ))}
            </ul>
          </div>
        )}

        {recommendedPaths.length > 0 && (
          <div class="space-y-2">
            <p class="text-[0.68rem] font-semibold tracking-[0.18em] text-foreground/45 uppercase">
              Recommended Paths
            </p>
            <div class="space-y-3">
              {recommendedPaths.map(item => (
                <a
                  href={item.href}
                  class="block rounded-2xl border border-border bg-background/65 px-4 py-3 transition hover:border-accent/35 hover:bg-background"
                >
                  <p class="font-semibold text-foreground">{item.label}</p>
                  {item.description && (
                    <p class="mt-1 text-xs leading-5 text-foreground/62">
                      {item.description}
                    </p>
                  )}
                </a>
              ))}
            </div>
          </div>
        )}

        <div class="flex flex-wrap gap-x-4 gap-y-2 border-t border-border pt-4 text-[0.72rem] text-foreground/58">
          {typeof sidecar?.content_stats?.total_posts === "number" && (
            <span>收录 {sidecar.content_stats.total_posts} 篇</span>
          )}
          {typeof sidecar?.content_stats?.featured_posts === "number" && (
            <span>精选 {sidecar.content_stats.featured_posts} 篇</span>
          )}
          {confidence && <span>置信度 {confidence}</span>}
          {generatedAt && <span>生成于 {generatedAt}</span>}
        </div>

        {notes.length > 0 && (
          <p class="text-xs leading-5 text-foreground/55">{notes[0]}</p>
        )}
      </div>
    ) : (
      <div class="mt-5 space-y-3 text-sm leading-6 text-foreground/72">
        <p>
          首页 Agent sidecar
          尚未生成，因此这里只展示空态，不会触发任何在线请求。
        </p>
        <p class="text-foreground/55">
          可运行 <code>npm run agent -- --changed</code> 或{" "}
          <code>npm run agent:build-home-panel</code> 生成静态导览。
        </p>
      </div>
    )
  }
</section>
