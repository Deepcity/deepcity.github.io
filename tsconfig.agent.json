{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "rootDir": ".",
    "outDir": ".tmp/agent-build",
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true
  },
  "include": ["src/agent/**/*.ts", "scripts/blog-agent.ts", "tests/blog-agent.test.ts"],
  "exclude": ["node_modules", "dist", "public/pagefind", ".astro"]
}
